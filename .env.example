# Environment Variables for Todo App
# Copy this file to .env.local and fill in the values.

# JWT secret for session signing — use a random 32+ character string in production
JWT_SECRET=change-this-to-a-random-secret-min-32-chars

# WebAuthn Relying Party configuration
# In development, leave as localhost.
# In production, set to your actual domain (no protocol, no port).
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Todo App
WEBAUTHN_RP_ORIGIN=http://localhost:3000

# Node environment
NODE_ENV=development
